NODE_ENV=development
LOG_LEVEL=info
PORT=4300
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/elamora_db
MIGRATION_DATABASE_URL=postgresql://elamora_migrator:change_me@127.0.0.1:5432/elamora_db
JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-characters
# Comma-separated browser origins allowed by CORS.
CORS_ORIGIN=http://localhost:8080

# Canonical URL used to build links in emails.
PUBLIC_APP_URL=http://localhost:8080

# Recipient of backup monitoring reports.
BACKUP_REPORT_EMAIL=alerts@example.com

# PostgreSQL backup and monitoring settings.
BACKUP_DIR=/var/backups/elamora
BACKUP_DB_NAME=elamora_db
BACKUP_RETENTION_DAYS=14
BACKUP_MAX_AGE_HOURS=36
BACKUP_MIN_SIZE_BYTES=1024
BACKUP_DISK_WARNING_PERCENT=85
BACKUP_MIN_ARCHIVE_ENTRIES=11

# ISO-style 2-letter country code used when no country is supplied.
DEFAULT_COUNTRY=XK

# Only orders created from this date can receive automatic admin reminders.
PENDING_PAYMENT_REMINDERS_START_AT=2026-01-01T00:00:00Z

COOKIE_SECURE=false
