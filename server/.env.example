NODE_ENV=development
PORT=4300
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/elamora_db
JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-characters
# Comma-separated allowed browser origins. First value is used as the public base URL in emails.
CORS_ORIGIN=http://localhost:8080
COOKIE_SECURE=false
